# MVP behavior
# local_whisper = use the installed Whisper CLI and FFmpeg
# demo = instant placeholder transcript for product-flow testing
TRANSCRIPTION_PROVIDER=local_whisper
WHISPER_MODEL=tiny
WHISPER_THREADS=2
WHISPER_TIMEOUT_SECONDS=600
TRANSCRIPTION_CHUNK_SECONDS=1200
TRANSLATION_PROVIDER=openai
OPENAI_TRANSLATION_MODEL=gpt-5-mini
SHORT_CLIP_SECONDS=45
SHORT_CLIP_COUNT=3
HIGHLIGHT_PROVIDER=openai
OPENAI_HIGHLIGHT_MODEL=gpt-5-mini
USE_CELERY=true
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Required for TRANSLATION_PROVIDER=openai.
OPENAI_API_KEY=
# GOOGLE_TRANSLATE_API_KEY=

